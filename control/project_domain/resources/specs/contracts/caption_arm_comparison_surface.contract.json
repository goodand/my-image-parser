{
  "name": "caption_arm_comparison_surface",
  "status": "implemented",
  "mode": "read_only",
  "source_of_truth": "control/project_domain/resources/specs/prose/SPEC_caption_arm_comparison_surface.md",
  "implementation_paths": [
    "scripts/caption_arm_comparison_lib.py",
    "scripts/run_caption_arm_comparison.py",
    "scripts/test_caption_arm_comparison_lib.py"
  ],
  "cli_surface": {
    "baseline_flag": "--baseline-ledger",
    "source_image_flag": "--source-image-path",
    "candidate_arm_flag": "--candidate-arm",
    "candidate_arm_spec_format": "execution_arm=ledger_path::fallback_input_surface",
    "candidate_arm_default_fallback_input_surface": "full_image_original",
    "candidate_arm_repeatable": true,
    "bundle_json_flag": "--bundle-json",
    "bundle_report_flag": "--bundle-report-md"
  },
  "ledger_source_glob": "control/project_agent_ops/registry/jobs/image_caption_jobs/*.json",
  "record_shape": {
    "required_fields": [
      "execution_arm",
      "ledger_path",
      "job_id",
      "image_id",
      "source_image_path",
      "status",
      "input_surface",
      "caption",
      "alt_text",
      "prompt_version"
    ],
    "optional_fields": [
      "model",
      "context_package_present",
      "context_review_status",
      "ocr_status",
      "context_package_json_path",
      "context_variant"
    ]
  },
  "promotion_gate": {
    "input": "context_review_status",
    "mapping": {
      "accepted": "candidate_ready",
      "reviewed_candidate": "comparison_ready_reviewed_branch",
      "pending_review": "comparison_only_pending_context_review",
      "default": "blocked_by_context_review"
    },
    "next_gate": "review_context_package"
  },
  "parity_audit": {
    "blocking_rules": [
      "missing_required_fields",
      "different_source_image"
    ],
    "nonblocking_drift": [
      "image_id",
      "prompt_version",
      "input_surface",
      "review_status",
      "context_variant",
      "ocr_status",
      "context_package_present"
    ],
    "comparison_anchor_key": "source_image_path",
    "reviewed_component_parent_anchor_field": "context_package.reviewed_component_enrichment.parent_source_image_path"
  },
  "surfaces": {
    "two_mode": {
      "function": "compare_caption_modes",
      "report_renderer": "render_comparison_report",
      "expected_mode_count": 2
    },
    "ready_arm_anchor": {
      "function": "compare_ready_caption_arms",
      "report_renderer": "render_multi_mode_comparison_report",
      "minimum_mode_count": 2,
      "status_fields": [
        "ready_arms",
        "blocked_arms",
        "comparison_scope",
        "comparison_ready"
      ]
    }
  },
  "bounded_artifacts": [
    "control/project_domain/resources/manifests/phase0_caption_two_mode_comparison_at2026_03_28.json",
    "control/project_domain/resources/manifests/phase0_caption_three_mode_comparison_at2026_03_28.json"
  ]
}
