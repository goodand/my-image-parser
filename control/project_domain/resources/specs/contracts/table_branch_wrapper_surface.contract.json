{
  "name": "table_branch_wrapper_surface",
  "status": "implemented",
  "mode": "read_only",
  "source_of_truth": "control/project_domain/resources/specs/prose/SPEC_table_branch_wrapper_surface.md",
  "implementation_paths": [
    "scripts/table_branch_wrapper_lib.py",
    "scripts/test_table_branch_wrapper_lib.py"
  ],
  "normalized_read_surface": {
    "glob": "control/project_domain/resources/manifests/*table*_normalized*.json",
    "required_top_level_fields": [
      "document_id",
      "page",
      "table_id",
      "rows"
    ]
  },
  "methods": {
    "get_tables": {
      "args": [
        "document_id"
      ],
      "returns": [
        "document_id",
        "page",
        "table_id",
        "source_image_path",
        "row_count",
        "column_count",
        "normalized_manifest_path"
      ]
    },
    "get_table_rows": {
      "args": [
        "table_id"
      ],
      "returns": [
        "table_id",
        "row_index",
        "cell_count",
        "cells"
      ],
      "ambiguity_rule": "fail_if_table_id_not_unique"
    },
    "get_cells": {
      "args": [
        "table_id"
      ],
      "returns": [
        "table_id",
        "row_index",
        "cell_id",
        "col_index",
        "text",
        "row_span",
        "col_span",
        "bbox",
        "confidence"
      ],
      "ambiguity_rule": "fail_if_table_id_not_unique"
    }
  }
}
