# Core API keys
OPENROUTER_API_KEY=sk-or-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Shared runtime roots for MCP wrappers.
# Leave commented to use the default XDG-style paths.
# MCP_STATE_DIR=$HOME/.local/state/my-image-parser/mcp
# MCP_CACHE_DIR=$HOME/.cache/my-image-parser/mcp

# Optional env file override for cv-mcp.
# CV_MCP_ENV_FILE=$PWD/.env

# Optional launcher and runtime overrides.
# Set these only when the default repo-local or PATH-based resolution is not valid.

# AGENT_TASK_MANAGER_BIN=
# AGENT_TASK_MANAGER_ENTRYPOINT=
# AGENT_TASK_MANAGER_SQLITE_PATH=

# CONPORT_WORKSPACE_ID=
# CONPORT_LOG_FILE=

# EXIFTOOL_BIN=/usr/local/bin/exiftool
# EXIFTOOL_INSTALL_HINT=Install ExifTool and set EXIFTOOL_BIN if it is not on PATH.

